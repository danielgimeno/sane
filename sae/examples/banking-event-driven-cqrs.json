      "type": "user",
      "label": "App Móvil",
      "position": { "x": 40, "y": 280 },
      "parameters": { "requests_per_second": 350 },
      "connections": {
        "outgoing": [
          { "target": "cdn1", "source_handle": "requests", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
