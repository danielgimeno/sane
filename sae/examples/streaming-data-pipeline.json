      "connections": {
        "outgoing": [
          { "target": "stream_enrich", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "producer_web", "source_handle": "out", "target_handle": "in" },
          { "source": "producer_mobile", "source_handle": "out", "target_handle": "in" },
          { "source": "producer_iot", "source_handle": "out", "target_handle": "in" }
        ]
