      "type": "microservice",
      "label": "Eventos Web",
      "position": { "x": 40, "y": 140 },
      "parameters": { "instances": 6, "events_per_second": 1200 },
      "connections": {
        "outgoing": [
          { "target": "kafka_raw", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
    {
      "id": "producer_mobile",
      "type": "microservice",
      "label": "Eventos Móvil",
      "position": { "x": 40, "y": 320 },
      "parameters": { "instances": 4, "events_per_second": 800 },
      "connections": {
        "outgoing": [
          { "target": "kafka_raw", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
    {
      "id": "producer_iot",
      "type": "microservice",
      "label": "Sensores IoT",
      "position": { "x": 40, "y": 500 },
      "parameters": { "instances": 2, "events_per_second": 3000 },
      "connections": {
        "outgoing": [
          { "target": "kafka_raw", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
    {
