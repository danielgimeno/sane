{
  "id": "web-with-database",
  "title": "API con base de datos",
  "description": "Flujo clásico: usuarios → API Gateway → servidor web → PostgreSQL con caché Redis",
  "category": "Básico",
  "nodes": [
    {
      "id": "user1",
      "type": "user",
      "label": "Clientes",
      "position": { "x": 40, "y": 160 },
      "parameters": { "requests_per_second": 30 },
      "connections": {
        "outgoing": [
          { "target": "gw1", "source_handle": "requests", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
    {
      "id": "gw1",
      "type": "api_gateway",
      "label": "API Gateway",
      "position": { "x": 240, "y": 160 },
      "parameters": { "rate_limit_rps": 500 },
      "connections": {
        "outgoing": [
          { "target": "ws1", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "user1", "source_handle": "requests", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "ws1",
      "type": "web_server",
      "label": "Backend API",
      "position": { "x": 460, "y": 160 },
      "parameters": { "workers": 8, "process_time_ms": 40 },
      "connections": {
        "outgoing": [
          { "target": "redis1", "source_handle": "out", "target_handle": "in" },
          { "target": "db1", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "gw1", "source_handle": "out", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "redis1",
      "type": "redis",
      "label": "Redis Cache",
      "position": { "x": 680, "y": 80 },
      "parameters": { "hit_ratio": 0.9, "memory_mb": 512 },
      "connections": {
        "outgoing": [],
        "incoming": [
          { "source": "ws1", "source_handle": "out", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "db1",
      "type": "database",
      "label": "PostgreSQL",
      "position": { "x": 680, "y": 240 },
      "parameters": { "max_connections": 100, "query_time_ms": 15 },
      "connections": {
        "outgoing": [],
        "incoming": [
          { "source": "ws1", "source_handle": "out", "target_handle": "in" }
        ]
      }
    }
  ]
}
