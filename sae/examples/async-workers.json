{
  "id": "async-workers",
  "title": "Procesamiento asíncrono",
  "description": "Cron job encola tareas en RabbitMQ; workers las procesan y persisten en base de datos",
  "category": "Mensajería",
  "nodes": [
    {
      "id": "cron1",
      "type": "cron_job",
      "label": "Scheduler",
      "position": { "x": 40, "y": 150 },
      "parameters": { "interval_seconds": 10 },
      "connections": {
        "outgoing": [
          { "target": "queue1", "source_handle": "trigger", "target_handle": "in" }
        ],
        "incoming": []
      }
    },
    {
      "id": "queue1",
      "type": "rabbitmq",
      "label": "RabbitMQ",
      "position": { "x": 260, "y": 150 },
      "parameters": { "prefetch_count": 10, "ack_mode": "manual" },
      "connections": {
        "outgoing": [
          { "target": "worker1", "source_handle": "out", "target_handle": "in" },
          { "target": "worker2", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "cron1", "source_handle": "trigger", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "worker1",
      "type": "microservice",
      "label": "Worker 1",
      "position": { "x": 500, "y": 80 },
      "parameters": { "instances": 2, "process_time_ms": 100 },
      "connections": {
        "outgoing": [
          { "target": "db1", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "queue1", "source_handle": "out", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "worker2",
      "type": "microservice",
      "label": "Worker 2",
      "position": { "x": 500, "y": 220 },
      "parameters": { "instances": 2, "process_time_ms": 100 },
      "connections": {
        "outgoing": [
          { "target": "db1", "source_handle": "out", "target_handle": "in" }
        ],
        "incoming": [
          { "source": "queue1", "source_handle": "out", "target_handle": "in" }
        ]
      }
    },
    {
      "id": "db1",
      "type": "database",
      "label": "PostgreSQL",
      "position": { "x": 740, "y": 150 },
      "parameters": { "max_connections": 50, "query_time_ms": 20 },
      "connections": {
        "outgoing": [],
        "incoming": [
          { "source": "worker1", "source_handle": "out", "target_handle": "in" },
          { "source": "worker2", "source_handle": "out", "target_handle": "in" }
        ]
      }
    }
  ]
}
